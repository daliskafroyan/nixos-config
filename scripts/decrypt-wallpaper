#!/usr/bin/env sh

set -eu

repo_dir="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
wallpaper_name="${1:-all}"
private_key_file="$HOME/.ssh/id_ed25519_personal"
if [ "$#" -ge 2 ]; then
  private_key_file="$2"
fi
target_dir="$HOME/.local/share/wallpapers"

if [ ! -f "$private_key_file" ]; then
  printf 'missing SSH private key: %s\n' "$private_key_file" >&2
  exit 1
fi

mkdir -p "$target_dir"

decrypt_one() {
  encrypted_file="$1"
  base_name="$(basename "$encrypted_file" .age)"
  target_file="$target_dir/$base_name"
  temp_file="$target_file.tmp"

  age -d -i "$private_key_file" -o "$temp_file" "$encrypted_file"
  mv "$temp_file" "$target_file"
  printf 'decrypted wallpaper -> %s\n' "$target_file"
}

if [ "$wallpaper_name" = "all" ]; then
  found=false

  for encrypted_file in "$repo_dir"/assets/wallpapers/*.mp4.age; do
    if [ ! -e "$encrypted_file" ]; then
      continue
    fi

    found=true
    decrypt_one "$encrypted_file"
  done

  if [ "$found" = false ]; then
    printf 'no encrypted wallpapers found in %s\n' "$repo_dir/assets/wallpapers" >&2
    exit 1
  fi
else
  encrypted_file="$repo_dir/assets/wallpapers/$wallpaper_name.mp4.age"

  if [ ! -f "$encrypted_file" ]; then
    printf 'missing encrypted wallpaper: %s\n' "$encrypted_file" >&2
    exit 1
  fi

  decrypt_one "$encrypted_file"
fi

if [ ! -e "$target_dir/current.mp4" ] && [ -f "$target_dir/1.mp4" ]; then
  ln -sfn "$target_dir/1.mp4" "$target_dir/current.mp4"
fi

printf 'active wallpaper pointer: %s\n' "$target_dir/current.mp4"
